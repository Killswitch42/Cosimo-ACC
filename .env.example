# Application
APP_NAME="Medici Analytica Accounting"
APP_ENV=development
# JWT signing key — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app refuses to start with this placeholder when DEBUG is off.
APP_SECRET_KEY=change-this-to-a-random-64-char-string
DEBUG=true

# Session cookie security.
#   COOKIE_SECURE=false  → works over plain HTTP (home LAN / Tailscale). Default.
#   COOKIE_SECURE=true   → set ONLY when served over HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Initial admin account (used by `python -m app.seed.run_seed`).
# Set a strong password here BEFORE seeding, or change it after first login.
ADMIN_EMAIL=admin@medicianalytica.cz
ADMIN_PASSWORD=changeme123

# Database
DATABASE_URL=postgresql+asyncpg://medici:medici_dev_pass@localhost:5432/medici_accounting
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Company defaults (Medici Analytica s.r.o.)
COMPANY_NAME="Medici Analytica s.r.o."
COMPANY_ICO=
COMPANY_DIC=
COMPANY_REGISTERED_OFFICE=
FISCAL_YEAR_START_MONTH=1

# xAI Grok (Phase 04 AI classifier — get key at console.x.ai)
XAI_API_KEY=

# Czech National Bank FX API (Phase 02)
CNB_API_BASE_URL=https://api.cnb.cz/cnbapi/exrates

# Finanční správa ePortál (Phase 05)
EPARTAL_BASE_URL=https://adisspr.mfcr.cz

# Filing + document output directories (Phase 05 / 07)
FILING_OUTPUT_DIR=/tmp/medici-analytica-filings
DOCUMENT_STORAGE_DIR=/tmp/medici-analytica-documents

# Google Drive backup (off by default). Setup:
#   1. Create a Google Cloud project, enable the Drive API.
#   2. Create a service account, download its JSON key.
#   3. Create a Drive folder, share it with the service account's email (Editor),
#      and copy the folder id from the URL.
GDRIVE_BACKUP_ENABLED=false
GDRIVE_SERVICE_ACCOUNT_FILE=
GDRIVE_BACKUP_FOLDER_ID=
BACKUP_KEEP_COUNT=14
# Name of the Postgres container to dump through when host pg_dump is absent.
PG_CONTAINER_NAME=medici-pg
