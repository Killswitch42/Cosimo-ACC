# Application
APP_NAME="Medici Analytica Accounting"
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-64-char-string
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://medici:medici_dev_pass@localhost:5432/medici_accounting
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Company defaults (Medici Analytica s.r.o.)
COMPANY_NAME="Medici Analytica s.r.o."
COMPANY_ICO=
COMPANY_DIC=
COMPANY_REGISTERED_OFFICE=
FISCAL_YEAR_START_MONTH=1

# xAI Grok (Phase 04 AI classifier — get key at console.x.ai)
XAI_API_KEY=

# Czech National Bank FX API (Phase 02)
CNB_API_BASE_URL=https://api.cnb.cz/cnbapi/exrates

# Finanční správa ePortál (Phase 05)
EPARTAL_BASE_URL=https://adisspr.mfcr.cz

# Filing + document output directories (Phase 05 / 07)
FILING_OUTPUT_DIR=/tmp/medici-analytica-filings
DOCUMENT_STORAGE_DIR=/tmp/medici-analytica-documents
